[alias]
	default-branch = !git symbolic-ref refs/remotes/origin/HEAD | cut -d'/' -f4
	ane = commit --amend --no-edit
	b = branch
	co = checkout
	com = !git checkout $(git default-branch)
	dc = diff --cached
	l = log --pretty='%C(auto)%h %C(cyan)%an %ad%C(auto)%d %s' --date=relative
	ll = l -1
	lb = !git l $(git default-branch)..HEAD
	pf = push --force-with-lease
	s = status -s
	dlb = "!f() { \
		main=\"${1:-$(git default-branch)}\"; \
		if ! git rev-parse --verify \"$main\" >/dev/null 2>&1; then \
			echo \"error: branch '$main' not found\" >&2; return 1; \
		fi; \
		git branch \
			| grep -v '^\\*' \
			| sed 's/^[[:space:]]*//' \
			| grep -v \"^${main}$\" \
			| while IFS= read -r b; do \
				if ! git cherry \"$main\" \"$b\" 2>/dev/null | grep -q '^+'; then \
					git branch -D \"$b\"; continue; \
				fi; \
				anc=$(git merge-base \"$main\" \"$b\" 2>/dev/null) || continue; \
				v=$(git commit-tree \"$b^{tree}\" -p \"$anc\" -m _ 2>/dev/null) || continue; \
				if ! git cherry \"$main\" \"$v\" 2>/dev/null | grep -q '^+'; then \
					git branch -D \"$b\"; \
				fi; \
			done; \
	}; f"
[core]
	pager = delta
	editor = code --wait
[credential]
	helper =
	helper = manager
[credential "helperselector"]
	selected = manager
[credential "https://dev.azure.com"]
	useHttpPath = true
[delta]
	navigate = true  # use n and N to move between diff sections
	dark = true      # or light = true, or omit for auto-detection
[init]
	defaultBranch = main
[interactive]
	diffFilter = delta --color-only
[log]
	abbrevCommit = true
[merge]
	conflictStyle = zdiff3
	tool = vscode
[mergetool "vscode"]
	cmd = code --wait --merge $REMOTE $LOCAL $BASE $MERGED
	keepBackup = false
[push]
	autoSetupRemote = true
[rebase]
	autosquash = true
[remote "origin"]
	prune = true
[user]
	name = Oskar Hermansson
	email = {{ .email }}
